# PostgreSQL Database Connection
DATABASE_HOST=your-db-host.pg.psdb.cloud
DATABASE_USERNAME=your_username
DATABASE_PASSWORD=your_password
DATABASE_NAME=postgres
DATABASE_PORT=5432

# Full connection string (alternative to individual settings)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=verify-full

# API Server Configuration
PORT=3000
NODE_ENV=production

# Shopify OAuth (from Shopify Partners → App → Settings → Credentials)
SHOPIFY_API_KEY=your_client_id_from_partners
SHOPIFY_API_SECRET=your_client_secret_from_partners
SHOPIFY_REDIRECT_URI=https://your-render-url.onrender.com/api/shopify/callback

# Email Alerts — Gmail SMTP (for Shopify stock-below-zero notifications)
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be on)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=RTS Alerts <your-gmail@gmail.com>

# Google Drive Import — AiM / Race Studio 3 data file watcher
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Enable "Google Drive API"
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Set Authorised Redirect URI to: https://your-domain.com/api/drive-import/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/drive-import/callback
