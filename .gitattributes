# Normalize line endings across machines (Windows + macOS via Dropbox)
# Treat everything as text and check out with LF to prevent CRLF/LF churn.
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# Windows batch files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.sqlite binary
*.db binary
